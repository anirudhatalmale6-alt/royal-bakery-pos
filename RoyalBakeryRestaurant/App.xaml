<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:RoyalBakeryRestaurant"
             x:Class="RoyalBakeryRestaurant.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="PageBg">#1A1A1A</Color>
            <Color x:Key="CardBg">#2A2A2A</Color>
            <Color x:Key="InputBg">#333333</Color>
            <Color x:Key="ItemRowBg">#2E2E2E</Color>
            <Color x:Key="TotalHighlight">#FFEB3B</Color>
            <Color x:Key="NumpadBg">#424242</Color>
            <Color x:Key="NumpadText">#E0E0E0</Color>
            <Color x:Key="ClearBtn">#EF5350</Color>
            <Color x:Key="ClearCartBtn">#616161</Color>
            <Color x:Key="PlaceOrderBtn">#4CAF50</Color>
            <Color x:Key="CatBread">#2196F3</Color>
            <Color x:Key="CatPastries">#9C27B0</Color>
            <Color x:Key="CatDrinks">#4CAF50</Color>
            <Color x:Key="CatSpecials">#F44336</Color>
            <Color x:Key="Gray300">#B0BEC5</Color>
            <Color x:Key="Gray400">#78909C</Color>
            <Color x:Key="Gray600">#546E7A</Color>
        </ResourceDictionary>
    </Application.Resources>
</Application>
