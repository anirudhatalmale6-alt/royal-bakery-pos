{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=RoyalBakery;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "PickMe": {
    "Enabled": true,
    "SandboxMode": true,
    "SandboxBaseUrl": "https://api-stage.mytaxi.com",
    "LiveBaseUrl": "https://api.pickme.lk",
    "Accounts": [
      {
        "Name": "BakeryAndRestaurant",
        "ApiKey": "YOUR_PICKME_API_KEY_1",
        "HasBakeryItems": true,
        "HasRestaurantItems": true
      },
      {
        "Name": "RestaurantOnly",
        "ApiKey": "YOUR_PICKME_API_KEY_2",
        "HasBakeryItems": false,
        "HasRestaurantItems": true
      }
    ],
    "PollIntervalSeconds": 30,
    "PollHoursBack": 2
  },
  "UberEats": {
    "Enabled": false,
    "BaseUrl": "https://api.uber.com/v1",
    "TokenUrl": "https://auth.uber.com/oauth/v2/token",
    "Accounts": [
      {
        "Name": "BakeryAndRestaurant",
        "ClientId": "YOUR_UBER_CLIENT_ID_1",
        "ClientSecret": "YOUR_UBER_CLIENT_SECRET_1",
        "StoreId": "YOUR_UBER_STORE_ID_1",
        "HasBakeryItems": true,
        "HasRestaurantItems": true
      },
      {
        "Name": "RestaurantOnly",
        "ClientId": "YOUR_UBER_CLIENT_ID_2",
        "ClientSecret": "YOUR_UBER_CLIENT_SECRET_2",
        "StoreId": "YOUR_UBER_STORE_ID_2",
        "HasBakeryItems": false,
        "HasRestaurantItems": true
      }
    ],
    "PollIntervalSeconds": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
