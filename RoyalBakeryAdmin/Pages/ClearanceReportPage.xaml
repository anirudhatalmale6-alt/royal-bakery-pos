<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="RoyalBakeryAdmin.Pages.ClearanceReportPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             BackgroundColor="#F0F2F5">

    <Grid RowDefinitions="Auto,Auto,*" Padding="30" RowSpacing="15">

        <Label Text="Stock Clearance Report"
               FontSize="28" FontAttributes="Bold" TextColor="#1A237E"/>

        <!-- Date Filters -->
        <Frame Grid.Row="1" BackgroundColor="White" Padding="12,10" CornerRadius="10" HasShadow="True">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12">
                <Label Text="From:" VerticalOptions="Center" TextColor="#212121" FontSize="14" FontAttributes="Bold"/>
                <DatePicker x:Name="FromDate" Grid.Column="1" TextColor="#212121" FontSize="14"/>
                <Label Grid.Column="2" Text="To:" VerticalOptions="Center" TextColor="#212121" FontSize="14" FontAttributes="Bold"/>
                <DatePicker x:Name="ToDate" Grid.Column="3" TextColor="#212121" FontSize="14"/>
                <Button Grid.Column="4" Text="Generate Report"
                        BackgroundColor="#1A237E" TextColor="White"
                        CornerRadius="8" HeightRequest="40" FontSize="14"
                        Clicked="Generate_Clicked"/>
            </Grid>
        </Frame>

        <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="15">

            <!-- Summary -->
            <FlexLayout Wrap="Wrap" JustifyContent="Start" Direction="Row">
                <Frame BackgroundColor="White" Padding="15" Margin="5" CornerRadius="10" HasShadow="True" WidthRequest="180">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Total Clearances" FontSize="12" TextColor="#757575"/>
                        <Label x:Name="TotalClearanceLabel" Text="0" FontSize="20"
                               FontAttributes="Bold" TextColor="#EF5350"/>
                    </VerticalStackLayout>
                </Frame>
                <Frame BackgroundColor="White" Padding="15" Margin="5" CornerRadius="10" HasShadow="True" WidthRequest="180">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Total Qty Cleared" FontSize="12" TextColor="#757575"/>
                        <Label x:Name="TotalQtyLabel" Text="0" FontSize="20"
                               FontAttributes="Bold" TextColor="#FF9800"/>
                    </VerticalStackLayout>
                </Frame>
            </FlexLayout>

            <!-- Clearance Table -->
            <Frame Grid.Row="1" BackgroundColor="White" Padding="0" CornerRadius="12" HasShadow="True">
                <Grid RowDefinitions="Auto,*">
                    <Grid ColumnDefinitions="150,2*,80,*,*"
                          Padding="12,8" BackgroundColor="#E8EAF6" ColumnSpacing="8">
                        <Label Text="Date/Time" FontAttributes="Bold" TextColor="#1A237E" FontSize="12"/>
                        <Label Grid.Column="1" Text="Item" FontAttributes="Bold" TextColor="#1A237E" FontSize="12"/>
                        <Label Grid.Column="2" Text="Qty" FontAttributes="Bold" TextColor="#1A237E" FontSize="12" HorizontalTextAlignment="Center"/>
                        <Label Grid.Column="3" Text="Reason" FontAttributes="Bold" TextColor="#1A237E" FontSize="12"/>
                        <Label Grid.Column="4" Text="Note" FontAttributes="Bold" TextColor="#1A237E" FontSize="12"/>
                    </Grid>
                    <CollectionView x:Name="ClearanceView" Grid.Row="1">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="150,2*,80,*,*"
                                      Padding="12,6" ColumnSpacing="8">
                                    <Label Text="{Binding DateStr}" FontSize="12" TextColor="#757575" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding ItemName}" FontSize="12" TextColor="#212121" VerticalOptions="Center"/>
                                    <Label Grid.Column="2" Text="{Binding Quantity}" FontSize="12" HorizontalTextAlignment="Center" TextColor="#212121" VerticalOptions="Center"/>
                                    <Label Grid.Column="3" Text="{Binding Reason}" FontSize="12" TextColor="#757575" VerticalOptions="Center"
                                           LineBreakMode="TailTruncation"/>
                                    <Label Grid.Column="4" Text="{Binding Note}" FontSize="12" TextColor="#9E9E9E" VerticalOptions="Center"
                                           LineBreakMode="TailTruncation"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
