<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:RoyalBakeryAdmin"
             x:Class="RoyalBakeryAdmin.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="Primary">#1A237E</Color>
            <Color x:Key="PrimaryDark">#0D1642</Color>
            <Color x:Key="Accent">#26A69A</Color>
            <Color x:Key="CardBg">#FFFFFF</Color>
            <Color x:Key="PageBg">#F0F2F5</Color>
            <Color x:Key="TextPrimary">#212121</Color>
            <Color x:Key="TextSecondary">#757575</Color>
            <Color x:Key="Success">#4CAF50</Color>
            <Color x:Key="Danger">#EF5350</Color>
            <Color x:Key="Warning">#FF9800</Color>
        </ResourceDictionary>
    </Application.Resources>
</Application>
