<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="RoyalBakeryCashier.Pages.CashierPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource PageBg}"
    Title="The Royal Bakery">

    <Grid RowDefinitions="Auto,*"
          ColumnDefinitions="2.8*,1.2*"
          Padding="15"
          ColumnSpacing="10">

        <!-- ================= TOP BAR ================= -->
        <Grid Grid.ColumnSpan="2" Padding="0,0,0,10">
            <Label Text="The Royal Bakery"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center"/>
            <HorizontalStackLayout HorizontalOptions="End" Spacing="8">
                <!-- Sales Order Search -->
                <Frame BackgroundColor="{StaticResource InputBg}"
                       Padding="0" CornerRadius="8"
                       BorderColor="{StaticResource Gray600}"
                       HeightRequest="36">
                    <HorizontalStackLayout Spacing="4" Padding="8,0">
                        <Entry x:Name="SalesOrderEntry"
                               Placeholder="Sales Order ID..."
                               PlaceholderColor="{StaticResource Gray400}"
                               TextColor="White"
                               FontSize="13"
                               WidthRequest="150"
                               HeightRequest="36"
                               BackgroundColor="Transparent"
                               Completed="SalesOrderEntry_Completed"/>
                        <Button Text="Load"
                                FontSize="12"
                                HeightRequest="30"
                                Padding="10,0"
                                CornerRadius="6"
                                BackgroundColor="{StaticResource CatDrinks}"
                                TextColor="White"
                                Clicked="LoadSalesOrder_Clicked"/>
                    </HorizontalStackLayout>
                </Frame>
                <Button Text="Sales History"
                        FontSize="13"
                        HeightRequest="36"
                        Padding="12,0"
                        CornerRadius="8"
                        BackgroundColor="{StaticResource CatPastries}"
                        TextColor="White"
                        Clicked="SalesHistory_Clicked"/>
            </HorizontalStackLayout>
        </Grid>

        <!-- ================= LEFT SIDE ================= -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="15">

                <!-- Categories — large 3-column grid -->
                <Frame BackgroundColor="{StaticResource CardBg}"
                       Padding="10"
                       CornerRadius="12"
                       BorderColor="{StaticResource Gray600}">

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Categories" FontAttributes="Bold" FontSize="16" TextColor="White"/>
                        <Grid x:Name="CategoryGrid"
                              ColumnDefinitions="*,*,*,*,*,*"
                              ColumnSpacing="18"
                              RowSpacing="18"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Items -->
                <Frame BackgroundColor="{StaticResource CardBg}"
                       Padding="10"
                       CornerRadius="12"
                       BorderColor="{StaticResource Gray600}">

                    <VerticalStackLayout Spacing="10">

                        <Label Text="Items"
                               FontSize="20"
                               TextColor="White"/>

                        <CollectionView x:Name="ItemsCollectionView"
                                        SelectionMode="Single"
                                        SelectionChanged="ItemsCollectionView_SelectionChanged">

                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical"
                                                 Span="5"
                                                 HorizontalItemSpacing="10"
                                                 VerticalItemSpacing="10"/>
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame Padding="10,8"
                                           Margin="0"
                                           BackgroundColor="{StaticResource ItemRowBg}"
                                           CornerRadius="8"
                                           BorderColor="{StaticResource Gray600}"
                                           HorizontalOptions="FillAndExpand">

                                        <VerticalStackLayout Spacing="4"
                                                             HorizontalOptions="Center"
                                                             VerticalOptions="Center">

                                            <Label Text="{Binding Name}"
                                                   FontSize="15"
                                                   FontAttributes="Bold"
                                                   TextColor="White"
                                                   HorizontalTextAlignment="Center"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"/>

                                            <Label Text="{Binding Price, StringFormat='LKR {0:F2}'}"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource TotalHighlight}"
                                                   HorizontalTextAlignment="Center"/>

                                            <Label Text="{Binding AvailableStock, StringFormat='Qty: {0}'}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource Gray300}"
                                                   HorizontalTextAlignment="Center"/>

                                        </VerticalStackLayout>

                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                        </CollectionView>

                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ================= RIGHT SIDE (RESPONSIVE CART) ================= -->
        <Frame Grid.Row="1"
               Grid.Column="1"
               BackgroundColor="{StaticResource CardBg}"
               Padding="10"
               CornerRadius="12"
               BorderColor="{StaticResource Gray600}">

            <Grid RowDefinitions="Auto,*,Auto,Auto,Auto,Auto"
                  RowSpacing="8">

                <!-- Title -->
                <Label Text="Bill"
                       FontSize="20"
                       TextColor="White"
                       HorizontalOptions="Center"/>

                <!-- Cart fills available space and scrolls -->
                <CollectionView Grid.Row="1"
                                x:Name="CartCollectionView"
                                VerticalOptions="FillAndExpand">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="8,6"
                                   Margin="0,3"
                                   BackgroundColor="{StaticResource ItemRowBg}"
                                   CornerRadius="8"
                                   BorderColor="{StaticResource Gray600}">

                                <Grid ColumnDefinitions="*,Auto,Auto"
                                      ColumnSpacing="6">

                                    <!-- Item name — tap to delete -->
                                    <Label Text="{Binding Name}"
                                           TextColor="White"
                                           FontSize="13"
                                           VerticalOptions="Center"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer CommandParameter="{Binding .}"
                                                                  Tapped="CartItemName_Tapped"/>
                                        </Label.GestureRecognizers>
                                    </Label>

                                    <!-- Qty controls — fixed width center block -->
                                    <HorizontalStackLayout Grid.Column="1"
                                                           Spacing="2"
                                                           VerticalOptions="Center">

                                        <Button Text="-"
                                                WidthRequest="28"
                                                HeightRequest="28"
                                                Padding="0"
                                                FontSize="16"
                                                BackgroundColor="{StaticResource CatSpecials}"
                                                TextColor="White"
                                                Clicked="DecreaseQuantity_Clicked"
                                                CommandParameter="{Binding .}"/>

                                        <Label Text="{Binding Quantity}"
                                               WidthRequest="28"
                                               TextColor="White"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center"
                                               VerticalOptions="Center"/>

                                        <Button Text="+"
                                                WidthRequest="28"
                                                HeightRequest="28"
                                                Padding="0"
                                                FontSize="16"
                                                BackgroundColor="{StaticResource PlaceOrderBtn}"
                                                TextColor="White"
                                                Clicked="IncreaseQuantity_Clicked"
                                                CommandParameter="{Binding .}"/>
                                    </HorizontalStackLayout>

                                    <!-- Total — right aligned, fixed width -->
                                    <Label Grid.Column="2"
                                           Text="{Binding Total, StringFormat='LKR {0:F2}'}"
                                           TextColor="{StaticResource TotalHighlight}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           WidthRequest="90"
                                           HorizontalTextAlignment="End"
                                           VerticalOptions="Center"/>
                                </Grid>

                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>

                <!-- Total -->
                <HorizontalStackLayout Grid.Row="2"
                                       HorizontalOptions="End"
                                       Spacing="10">

                    <Label x:Name="TotalLabel" Text="Total: LKR 0.00" TextColor="{StaticResource TotalHighlight}" FontSize="16" FontAttributes="Bold"/>
                </HorizontalStackLayout>

                <!-- Quantity -->
                <Entry Grid.Row="3"
                       x:Name="QuantityEntry"
                       Placeholder="Type quantity then tap item"
                       PlaceholderColor="{StaticResource Gray400}"
                       TextColor="White"
                       BackgroundColor="{StaticResource InputBg}"
                       IsReadOnly="True"
                       Keyboard="Numeric"/>

                <!-- KEYPAD — bigger buttons, 0 in center -->
                <Grid Grid.Row="4"
                      RowDefinitions="*,*,*,*"
                      ColumnDefinitions="*,*,*"
                      ColumnSpacing="6"
                      RowSpacing="6">

                    <Button Text="1" HeightRequest="58" FontSize="20" BackgroundColor="{StaticResource NumpadBg}" TextColor="{StaticResource NumpadText}" Clicked="Keypad_Clicked"/>
                    <Button Grid.Column="1" Text="2" HeightRequest="58" FontSize="20" BackgroundColor="{StaticResource NumpadBg}" TextColor="{StaticResource NumpadText}" Clicked="Keypad_Clicked"/>
                    <Button Grid.Column="2" Text="3" HeightRequest="58" FontSize="20" BackgroundColor="{StaticResource NumpadBg}" TextColor="{StaticResource NumpadText}" Clicked="Keypad_Clicked"/>

                    <Button Grid.Row="1" Text="4" HeightRequest="58" FontSize="20" BackgroundColor="{StaticResource NumpadBg}" TextColor="{StaticResource NumpadText}" Clicked="Keypad_Clicked"/>
                    <Button Grid.Row="1" Grid.Column="1" Text="5" HeightRequest="58" FontSize="20" BackgroundColor="{StaticResource NumpadBg}" TextColor="{StaticResource NumpadText}" Clicked="Keypad_Clicked"/>
                    <Button Grid.Row="1" Grid.Column="2" Text="6" HeightRequest="58" FontSize="20" BackgroundColor="{StaticResource NumpadBg}" TextColor="{StaticResource NumpadText}" Clicked="Keypad_Clicked"/>

                    <Button Grid.Row="2" Text="7" HeightRequest="58" FontSize="20" BackgroundColor="{StaticResource NumpadBg}" TextColor="{StaticResource NumpadText}" Clicked="Keypad_Clicked"/>
                    <Button Grid.Row="2" Grid.Column="1" Text="8" HeightRequest="58" FontSize="20" BackgroundColor="{StaticResource NumpadBg}" TextColor="{StaticResource NumpadText}" Clicked="Keypad_Clicked"/>
                    <Button Grid.Row="2" Grid.Column="2" Text="9" HeightRequest="58" FontSize="20" BackgroundColor="{StaticResource NumpadBg}" TextColor="{StaticResource NumpadText}" Clicked="Keypad_Clicked"/>

                    <Button Grid.Row="3" Text="Clear" HeightRequest="58" FontSize="16"
                            BackgroundColor="{StaticResource ClearBtn}"
                            TextColor="White"
                            Clicked="ClearKeypad_Clicked"/>

                    <Button Grid.Row="3" Grid.Column="1" Text="0" HeightRequest="58" FontSize="20"
                            BackgroundColor="{StaticResource NumpadBg}" TextColor="{StaticResource NumpadText}"
                            Clicked="Keypad_Clicked"/>

                    <Button Grid.Row="3" Grid.Column="2"
                            Text="CLR CART" HeightRequest="58" FontSize="14"
                            BackgroundColor="{StaticResource ClearCartBtn}"
                            TextColor="{StaticResource NumpadText}"
                            Clicked="ClearCart_Clicked"/>
                </Grid>

                <!-- PAY BUTTON below keypad -->
                <Button Grid.Row="5"
                        Text="Pay"
                        BackgroundColor="{StaticResource PlaceOrderBtn}"
                        TextColor="White"
                        FontSize="20"
                        FontAttributes="Bold"
                        HeightRequest="56"
                        CornerRadius="10"
                        Clicked="PlaceOrder_Clicked"/>

            </Grid>

        </Frame>

    </Grid>
</ContentPage>