<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="RoyalBakeryCashier.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource PageBg}"
    Shell.NavBarIsVisible="False"
    NavigationPage.HasNavigationBar="False"
    Title="Login">

    <Grid VerticalOptions="Center" HorizontalOptions="Center">
        <Frame BackgroundColor="{StaticResource CardBg}"
               Padding="50,40"
               CornerRadius="16"
               BorderColor="{StaticResource Gray600}"
               WidthRequest="400">

            <VerticalStackLayout Spacing="16" HorizontalOptions="Center">

                <Label Text="The Royal Bakery"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"/>

                <Label x:Name="ModeLabel"
                       Text="Cashier Login"
                       FontSize="16"
                       TextColor="{StaticResource Gray300}"
                       HorizontalTextAlignment="Center"/>

                <BoxView HeightRequest="1"
                         Color="{StaticResource Gray600}"
                         Margin="0,8"/>

                <!-- Username -->
                <Label Text="Username" FontSize="13" TextColor="{StaticResource Gray300}"/>
                <Frame BackgroundColor="{StaticResource InputBg}"
                       Padding="0" CornerRadius="8"
                       BorderColor="{StaticResource Gray600}"
                       HeightRequest="44">
                    <Entry x:Name="UsernameEntry"
                           Placeholder="Enter username"
                           PlaceholderColor="{StaticResource Gray400}"
                           TextColor="White"
                           FontSize="15"
                           HeightRequest="44"
                           BackgroundColor="Transparent"
                           Completed="Password_Completed"/>
                </Frame>

                <!-- Password -->
                <Label Text="Password" FontSize="13" TextColor="{StaticResource Gray300}"/>
                <Frame BackgroundColor="{StaticResource InputBg}"
                       Padding="0" CornerRadius="8"
                       BorderColor="{StaticResource Gray600}"
                       HeightRequest="44">
                    <Entry x:Name="PasswordEntry"
                           Placeholder="Enter password"
                           PlaceholderColor="{StaticResource Gray400}"
                           TextColor="White"
                           FontSize="15"
                           HeightRequest="44"
                           IsPassword="True"
                           BackgroundColor="Transparent"
                           Completed="Login_Clicked"/>
                </Frame>

                <!-- Error message -->
                <Label x:Name="ErrorLabel"
                       Text=""
                       TextColor="OrangeRed"
                       FontSize="13"
                       HorizontalTextAlignment="Center"
                       IsVisible="False"/>

                <!-- Login Button -->
                <Button x:Name="LoginBtn"
                        Text="Login"
                        BackgroundColor="{StaticResource PlaceOrderBtn}"
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        CornerRadius="10"
                        Clicked="Login_Clicked"/>

                <Label Text="Powered by EzyCode — www.ezycode.lk"
                       FontSize="11"
                       TextColor="{StaticResource Gray600}"
                       HorizontalTextAlignment="Center"
                       Margin="0,10,0,0"/>

            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>
