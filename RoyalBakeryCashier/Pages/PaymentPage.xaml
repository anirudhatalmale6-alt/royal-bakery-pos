<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="RoyalBakeryCashier.Pages.PaymentPage"
    BackgroundColor="{StaticResource PageBg}"
    Shell.NavBarIsVisible="False"
    NavigationPage.HasNavigationBar="False"
    Title="Payment">

    <!-- Full-screen grid: centers the popup card -->
    <Grid BackgroundColor="#80000000" Padding="0">
        <Frame BackgroundColor="{StaticResource CardBg}"
               BorderColor="{StaticResource NumpadBg}"
               CornerRadius="16"
               Padding="20"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               WidthRequest="540"
               HasShadow="True">

            <Grid ColumnDefinitions="1.2*,*" ColumnSpacing="16">

                <!-- LEFT: Total + Cash/Card fields + Balance -->
                <VerticalStackLayout Spacing="10">

                    <Label Text="Payment"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"
                           Margin="0,0,0,4" />

                    <!-- Total amount -->
                    <Frame BackgroundColor="{StaticResource ItemRowBg}" CornerRadius="10" Padding="12" BorderColor="{StaticResource Gray600}">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Order Total" TextColor="{StaticResource Gray300}" FontSize="16" VerticalOptions="Center"/>
                            <Label x:Name="TotalLabel" Grid.Column="1" FontSize="22" FontAttributes="Bold"
                                   TextColor="{StaticResource TotalHighlight}" HorizontalOptions="End"/>
                        </Grid>
                    </Frame>

                    <!-- Cash + Card side by side -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Frame BackgroundColor="{StaticResource ItemRowBg}" CornerRadius="8" Padding="10" BorderColor="{StaticResource Gray600}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="CASH" FontSize="12" TextColor="{StaticResource Gray300}"/>
                                <Entry x:Name="CashEntry"
                                       Placeholder="0"
                                       PlaceholderColor="{StaticResource Gray400}"
                                       TextColor="White"
                                       BackgroundColor="{StaticResource InputBg}"
                                       FontSize="18"
                                       HorizontalTextAlignment="End"
                                       Keyboard="Numeric"
                                       TextChanged="AmountChanged"/>
                            </VerticalStackLayout>
                        </Frame>
                        <Frame Grid.Column="1" BackgroundColor="{StaticResource ItemRowBg}" CornerRadius="8" Padding="10" BorderColor="{StaticResource Gray600}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="CARD" FontSize="12" TextColor="{StaticResource Gray300}"/>
                                <Entry x:Name="CardEntry"
                                       Placeholder="0"
                                       PlaceholderColor="{StaticResource Gray400}"
                                       TextColor="White"
                                       BackgroundColor="{StaticResource InputBg}"
                                       FontSize="18"
                                       HorizontalTextAlignment="End"
                                       Keyboard="Numeric"
                                       TextChanged="AmountChanged"/>
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>

                    <!-- Balance display -->
                    <Frame x:Name="BalanceFrame" BackgroundColor="{StaticResource ItemRowBg}" CornerRadius="10" Padding="12" BorderColor="{StaticResource Gray600}">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label x:Name="BalanceTitle" Text="Balance" TextColor="{StaticResource Gray300}" FontSize="15" VerticalOptions="Center"/>
                            <Label x:Name="BalanceLabel" Grid.Column="1" Text="Rs. 0.00" FontSize="20" FontAttributes="Bold"
                                   TextColor="OrangeRed" HorizontalOptions="End"/>
                        </Grid>
                    </Frame>

                    <!-- Change display (visible when overpaid) -->
                    <Frame x:Name="ChangeFrame" BackgroundColor="#1B3A1B" CornerRadius="10" Padding="12" BorderColor="#4CAF50" IsVisible="False">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Change" TextColor="#81C784" FontSize="15" VerticalOptions="Center"/>
                            <Label x:Name="ChangeLabel" Grid.Column="1" Text="Rs. 0.00" FontSize="20" FontAttributes="Bold"
                                   TextColor="#4CAF50" HorizontalOptions="End"/>
                        </Grid>
                    </Frame>

                </VerticalStackLayout>

                <!-- RIGHT: Tabs + Numpad + Cancel/Confirm -->
                <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">

                    <!-- Cash/Card tab selector -->
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,0,0,4">
                        <Button x:Name="CashTabBtn" Text="Cash" BackgroundColor="{StaticResource CatBread}" TextColor="White"
                                FontSize="13" HeightRequest="36" WidthRequest="90" CornerRadius="8" Clicked="CashTab_Clicked"/>
                        <Button x:Name="CardTabBtn" Text="Card" BackgroundColor="{StaticResource Gray600}" TextColor="White"
                                FontSize="13" HeightRequest="36" WidthRequest="90" CornerRadius="8" Clicked="CardTab_Clicked"/>
                    </HorizontalStackLayout>

                    <!-- Numpad 4-column: 1-9, backspace, clear, 0, dot -->
                    <Grid RowSpacing="6" ColumnSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="48"/>
                            <RowDefinition Height="48"/>
                            <RowDefinition Height="48"/>
                            <RowDefinition Height="48"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Text="1" Grid.Row="0" Grid.Column="0" FontSize="18" CornerRadius="8" BackgroundColor="{StaticResource NumpadBg}" TextColor="{StaticResource NumpadText}" Clicked="Keypad_Clicked"/>
                        <Button Text="2" Grid.Row="0" Grid.Column="1" FontSize="18" CornerRadius="8" BackgroundColor="{StaticResource NumpadBg}" TextColor="{StaticResource NumpadText}" Clicked="Keypad_Clicked"/>
                        <Button Text="3" Grid.Row="0" Grid.Column="2" FontSize="18" CornerRadius="8" BackgroundColor="{StaticResource NumpadBg}" TextColor="{StaticResource NumpadText}" Clicked="Keypad_Clicked"/>
                        <Button Text="&#x232B;" Grid.Row="0" Grid.Column="3" FontSize="18" CornerRadius="8" BackgroundColor="{StaticResource ClearCartBtn}" TextColor="{StaticResource NumpadText}" Clicked="DeleteKeypad_Clicked"/>

                        <Button Text="4" Grid.Row="1" Grid.Column="0" FontSize="18" CornerRadius="8" BackgroundColor="{StaticResource NumpadBg}" TextColor="{StaticResource NumpadText}" Clicked="Keypad_Clicked"/>
                        <Button Text="5" Grid.Row="1" Grid.Column="1" FontSize="18" CornerRadius="8" BackgroundColor="{StaticResource NumpadBg}" TextColor="{StaticResource NumpadText}" Clicked="Keypad_Clicked"/>
                        <Button Text="6" Grid.Row="1" Grid.Column="2" FontSize="18" CornerRadius="8" BackgroundColor="{StaticResource NumpadBg}" TextColor="{StaticResource NumpadText}" Clicked="Keypad_Clicked"/>
                        <Button Text="Clear" Grid.Row="1" Grid.Column="3" FontSize="12" CornerRadius="8" BackgroundColor="{StaticResource ClearBtn}" TextColor="White" Clicked="ClearKeypad_Clicked"/>

                        <Button Text="7" Grid.Row="2" Grid.Column="0" FontSize="18" CornerRadius="8" BackgroundColor="{StaticResource NumpadBg}" TextColor="{StaticResource NumpadText}" Clicked="Keypad_Clicked"/>
                        <Button Text="8" Grid.Row="2" Grid.Column="1" FontSize="18" CornerRadius="8" BackgroundColor="{StaticResource NumpadBg}" TextColor="{StaticResource NumpadText}" Clicked="Keypad_Clicked"/>
                        <Button Text="9" Grid.Row="2" Grid.Column="2" FontSize="18" CornerRadius="8" BackgroundColor="{StaticResource NumpadBg}" TextColor="{StaticResource NumpadText}" Clicked="Keypad_Clicked"/>
                        <Button Text="." Grid.Row="2" Grid.Column="3" FontSize="18" CornerRadius="8" BackgroundColor="{StaticResource NumpadBg}" TextColor="{StaticResource NumpadText}" Clicked="Keypad_Clicked"/>

                        <Button Text="0" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" FontSize="18" CornerRadius="8" BackgroundColor="{StaticResource NumpadBg}" TextColor="{StaticResource NumpadText}" Clicked="Keypad_Clicked"/>
                    </Grid>

                    <!-- Cancel + Confirm side by side -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,4,0,0">
                        <Button Text="Cancel"
                                BackgroundColor="{StaticResource CancelBtn}"
                                TextColor="White"
                                FontSize="16"
                                FontAttributes="Bold"
                                HeightRequest="48"
                                CornerRadius="10"
                                Clicked="Cancel_Clicked"/>
                        <Button x:Name="ConfirmBtn"
                                Grid.Column="1"
                                Text="Confirm"
                                BackgroundColor="{StaticResource PlaceOrderBtn}"
                                TextColor="White"
                                FontSize="16"
                                FontAttributes="Bold"
                                HeightRequest="48"
                                CornerRadius="10"
                                IsEnabled="False"
                                Clicked="Confirm_Clicked"/>
                    </Grid>

                </VerticalStackLayout>

            </Grid>
        </Frame>
    </Grid>
</ContentPage>