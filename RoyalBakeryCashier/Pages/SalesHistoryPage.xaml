<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="RoyalBakeryCashier.Pages.SalesHistoryPage"
    BackgroundColor="{StaticResource PageBg}"
    Shell.NavBarIsVisible="False"
    NavigationPage.HasNavigationBar="False"
    Title="Sales History">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20" RowSpacing="12">

        <!-- Header -->
        <HorizontalStackLayout Spacing="16" VerticalOptions="Center">
            <Label Text="Sales History"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center"/>
            <Label x:Name="CountLabel"
                   FontSize="14"
                   TextColor="{StaticResource Gray300}"
                   VerticalOptions="Center"/>
        </HorizontalStackLayout>

        <!-- Sales list -->
        <CollectionView Grid.Row="1"
                        x:Name="SalesListView"
                        VerticalOptions="FillAndExpand">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="12"
                           Margin="0,4"
                           BackgroundColor="{StaticResource CardBg}"
                           CornerRadius="10"
                           BorderColor="{StaticResource Gray600}">

                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="4" ColumnSpacing="10">

                            <!-- Invoice number + Date -->
                            <Label Text="{Binding InvoiceNumber}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="White"/>
                            <Label Grid.Row="1"
                                   Text="{Binding DateTimeFormatted}"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray300}"/>

                            <!-- Items summary -->
                            <Label Grid.Row="2"
                                   Text="{Binding ItemsSummary}"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray400}"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1"/>

                            <!-- Total + Payment info -->
                            <VerticalStackLayout Grid.Column="1" Grid.RowSpan="2"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="{Binding TotalFormatted}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TotalHighlight}"
                                       HorizontalTextAlignment="End"/>
                                <Label Text="{Binding PaymentMethod}"
                                       FontSize="11"
                                       TextColor="{StaticResource Gray300}"
                                       HorizontalTextAlignment="End"/>
                            </VerticalStackLayout>

                            <!-- Action buttons -->
                            <HorizontalStackLayout Grid.Row="2" Grid.Column="1"
                                                   Spacing="6"
                                                   HorizontalOptions="End">
                                <Button Text="View"
                                        FontSize="12"
                                        HeightRequest="32"
                                        WidthRequest="70"
                                        Padding="0"
                                        CornerRadius="6"
                                        BackgroundColor="{StaticResource CatBread}"
                                        TextColor="White"
                                        CommandParameter="{Binding SaleId}"
                                        Clicked="View_Clicked"/>
                                <Button Text="Reprint"
                                        FontSize="12"
                                        HeightRequest="32"
                                        WidthRequest="80"
                                        Padding="0"
                                        CornerRadius="6"
                                        BackgroundColor="{StaticResource CatPastries}"
                                        TextColor="White"
                                        CommandParameter="{Binding SaleId}"
                                        Clicked="Reprint_Clicked"/>
                            </HorizontalStackLayout>

                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <Label Text="No sales yet"
                       FontSize="16"
                       TextColor="{StaticResource Gray400}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </CollectionView.EmptyView>

        </CollectionView>

        <!-- Close button -->
        <Button Grid.Row="2"
                Text="Close"
                BackgroundColor="{StaticResource CancelBtn}"
                TextColor="White"
                FontSize="16"
                FontAttributes="Bold"
                HeightRequest="48"
                CornerRadius="10"
                Clicked="Close_Clicked"/>

    </Grid>
</ContentPage>
